# Life OS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to Git.

# ── MongoDB ──────────────────────────────────────────────
# Atlas connection string (recommended for production)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DATABASE_NAME=life_os_db

# ── MCP Server (deployed mcpserver Cloud Run URL) ────────
# Set this to the /sse endpoint of your deployed MCP server
MCP_SERVER=https://lifeos-mcp-server-<hash>-<region>.a.run.app/sse

# ── LLM / AI Provider ────────────────────────────────────
LLM_API_KEY=<your-api-key>
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MODEL_NAME=gemini-2.5-flash

# ── Server ───────────────────────────────────────────────
# Cloud Run injects PORT automatically.
# Only set this for local development.
PORT=8000

# Life OS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to Git.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas connection string (recommended for production)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DATABASE_NAME=life_os_db

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-please
# Token lifetime in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MCP Server (separate service — mcpserver/) ────────────────────────────────
# Used only by the MCP service, not this backend.
# MCP_SERVER=https://lifeos-mcp-server-<hash>-<region>.a.run.app/sse

# ── Server ────────────────────────────────────────────────────────────────────
# Cloud Run injects PORT automatically.
# Only set for local development.
PORT=8000

# Life OS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to Git.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas connection string (recommended for production)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DATABASE_NAME=life_os_db

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-please
# Token lifetime in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MCP Server (endpoint for UniClient) ────────────────────────────────────────
MCP_SERVER=http://127.0.0.1:8001/sse

# ── LLM Provider (used by UniLLM) ───────────────────────────────────────────────
# API key for your LLM provider (OpenAI, Groq, Gemini, NVIDIA NIM, etc.)
LLM_API_KEY=sk-...
# Base URL — omit for default OpenAI; set for compatible providers:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_BASE_URL=
# Model name
LLM_MODEL_NAME=gpt-4o

# ── Server ────────────────────────────────────────────────────────────────────
# Cloud Run injects PORT automatically.
# Only set for local development.
PORT=8000

# Life OS MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# ── MongoDB ──────────────────────────────────
# Local:       mongodb://localhost:27017
# Atlas:       mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=life_os_db

# ── Transport ────────────────────────────────
# "stdio" for local / Claude Desktop usage
# "sse"   for Cloud Run / HTTP-based clients
MCP_TRANSPORT=sse

# ── Server ───────────────────────────────────
# Cloud Run injects PORT automatically; set here only for local SSE testing
PORT=8080
